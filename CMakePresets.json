{
  "version": 3,
  "configurePresets": [
    {
      "name": "base-vcpkg",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "http-server-debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_FUZZING": "OFF",
        "ENABLE_ASAN": "ON",
        "ENABLE_TSAN": "OFF",
        "ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "http-server-tsan",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_FUZZING": "OFF",
        "ENABLE_ASAN": "OFF",
        "ENABLE_TSAN": "ON",
        "ENABLE_UBSAN": "OFF"
      }
    },
    {
      "name": "http-server-fuzz",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_FUZZING": "ON",
        "ENABLE_ASAN": "ON",
        "ENABLE_TSAN": "OFF",
        "ENABLE_UBSAN": "OFF"
      }
    },
    {
      "name": "http-server-release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_FUZZING": "OFF",
        "ENABLE_ASAN": "OFF",
        "ENABLE_TSAN": "OFF",
        "ENABLE_UBSAN": "OFF"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (ASan+UBSan)",
      "description": "Default dev mode: Debug with ASan+UBSan. TSan and fuzzing are separate presets.",
      "inherits": ["base-vcpkg", "http-server-debug"],
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "tsan",
      "displayName": "Debug (TSan)",
      "description": "Portable debug build with ThreadSanitizer. Do not combine with ASan. Best on Linux.",
      "inherits": ["base-vcpkg", "http-server-tsan"],
      "binaryDir": "${sourceDir}/build-tsan"
    },
    {
      "name": "fuzz",
      "displayName": "Fuzz (libFuzzer + ASan)",
      "description": "Fuzzing mode: libFuzzer with ASan enabled. Uses build-fuzz/.",
      "inherits": ["base-vcpkg", "http-server-fuzz"],
      "binaryDir": "${sourceDir}/build-fuzz",
      "cacheVariables": {}
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Release build (no sanitizers).",
      "inherits": ["base-vcpkg", "http-server-release"],
      "binaryDir": "${sourceDir}/build-release"
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "fuzz",
      "configurePreset": "fuzz"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "fuzz",
      "configurePreset": "fuzz"
    }
  ]
}
